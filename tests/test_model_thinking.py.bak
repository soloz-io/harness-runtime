"""Validate model thinking-mode capabilities for structured-output workflows.

Hardcode TEST_MODEL at the top of this file to target a different model.
Run with:  python3 -m pytest tests/test_model_thinking.py -v -s --no-header
"""

from __future__ import annotations

import json
from typing import Any

import pytest

# ================================================================== #
#  CONFIG — change this to test a different model                    #
# ================================================================== #
TEST_MODEL: dict[str, Any] = {
    "provider": "openai",
    "model": "deepseek-v4-flash",
    # "provider": "openai",
    # "model": "deepseek-chat",
    # "provider": "anthropic",
    # "model": "claude-sonnet-4-20250514",
}

# ================================================================== #
#  API key resolution                                                 #
# ================================================================== #

import os

# Ensure monkey-patches in core.structured_output are applied (patches
# _convert_dict_to_message and _convert_message_to_dict for
# reasoning_content preservation in DeepSeek thinking mode).
import core  # noqa: F401

_WAYPOINT_SDK_ENV = os.path.join(
    os.path.dirname(__file__),                    # harness-runtime/tests/
    "..", "..", "waypoint",                       # up to .../soloz-io/waypoint
    "packages", "waypoint-sdk", ".env",
)


def _resolve_deepseek_api_key() -> str:
    """Return a DeepSeek-compatible API key, checking env + .env fallback."""
    key = os.environ.get("DEEPSEEK_API_KEY")
    if key:
        return key
    # Fallback: read AI_GATEWAY_API_KEY from waypoint-sdk .env
    try:
        env_path = os.path.normpath(_WAYPOINT_SDK_ENV)
        with open(env_path) as f:
            for line in f:
                line = line.strip()
                if line.startswith("AI_GATEWAY_API_KEY="):
                    return line.split("=", 1)[1]
    except FileNotFoundError:
        pass
    raise RuntimeError(
        "No DeepSeek API key found. Set DEEPSEEK_API_KEY or ensure "
        "packages/waypoint-sdk/.env contains AI_GATEWAY_API_KEY"
    )


# ================================================================== #
#  Shared helpers                                                     #
# ================================================================== #


def _make_model(
    *,
    thinking_disabled: bool = False,
) -> Any:
    from core.model_factory import ModelFactory

    # Ensure correct API key is in environment when running outside
    # the waypoint-sdk subprocess context.
    model_name = TEST_MODEL["model"]
    if model_name.startswith("deepseek") and "DEEPSEEK_API_KEY" not in os.environ:
        os.environ["DEEPSEEK_API_KEY"] = _resolve_deepseek_api_key()

    extra: dict[str, Any] = {}
    if thinking_disabled:
        extra["extra_body"] = {"thinking": {"type": "disabled"}}
    return ModelFactory.create_model(
        provider=TEST_MODEL["provider"],
        model_name=TEST_MODEL["model"],
        **extra,
    )


# OpenAI-format tool definition (no LangChain StructuredTool wrapper)
_WEATHER_TOOL: dict[str, Any] = {
    "type": "function",
    "function": {
        "name": "get_weather",
        "description": "Get weather for a location",
        "parameters": {
            "type": "object",
            "properties": {
                "location": {
                    "type": "string",
                    "description": "City name, e.g. Tokyo",
                },
            },
            "required": ["location"],
        },
    },
}

# OpenAI-format JSON schema for structured-output (reviewer scenario)
_REVIEW_SCHEMA: dict[str, Any] = {
    "type": "json_schema",
    "json_schema": {
        "name": "review",
        "schema": {
            "type": "object",
            "properties": {
                "approved": {"type": "boolean"},
                "feedback": {"type": "string"},
            },
            "required": ["approved", "feedback"],
            "additionalProperties": False,
        },
    },
}


# ================================================================== #
#  Tests                                                             #
# ================================================================== #


class TestThinkingModeCapabilities:
    """Probe model behaviour around thinking + tool_choice + reasoning_content."""

    def test_thinking_with_tool_call(self) -> None:
        """Model with thinking enabled + tool calls.

        If this succeeds, the model supports thinking + tools (>= V3.2).
        If it fails, the model or API rejected the request.
        """
        model = _make_model()
        messages: list[dict[str, Any]] = [
            {"role": "system", "content": "You are a helpful assistant."},
            {"role": "user", "content": "What's the weather in Tokyo?"},
        ]
        try:
            result = model.invoke(messages, tools=[_WEATHER_TOOL])
            print(f"  content: {result.content!r}")
            print(f"  tool_calls={result.tool_calls!r}")
            rc = result.additional_kwargs.get("reasoning_content")
            print(f"  reasoning_content={'present' if rc else 'absent'} (len={len(rc) if rc else 0})")
        except Exception as e:
            err = str(e)
            if "thinking" in err.lower() and "tool" in err.lower():
                pytest.skip(f"Model {TEST_MODEL['model']} does not support thinking + tools: {err}")
            raise

    def test_thinking_with_structured_output(self) -> None:
        """Model with thinking enabled + structured output (json_schema response_format).

        Tests whether the model supports response_format with thinking enabled.
        If this fails, thinking must be disabled for structured-output nodes.
        """
        model = _make_model()
        messages = [
            {"role": "system", "content": "You are a reviewer. Output structured feedback."},
            {"role": "user", "content": "Review this PR: fix button click in Safari"},
        ]
        try:
            result = model.invoke(messages, response_format=_REVIEW_SCHEMA)
            print(f"  content: {result.content!r}")
            rc = result.additional_kwargs.get("reasoning_content")
            print(f"  reasoning_content={'present' if rc else 'absent'}")
        except Exception as e:
            err = str(e)
            if "response_format" in err.lower() or "tool_choice" in err.lower() or "thinking" in err.lower():
                pytest.skip(
                    f"Model {TEST_MODEL['model']} does not support "
                    f"thinking + response_format: {err}"
                )
            raise

    def test_reasoning_content_preserved_through_serialization(self) -> None:
        """Monkey-patch injects reasoning_content into serialized dict."""
        from langchain_core.messages import AIMessage
        from langchain_openai.chat_models.base import _convert_message_to_dict

        msg = AIMessage(
            content="Final answer",
            additional_kwargs={"reasoning_content": "Chain of thought..."},
            tool_calls=[{"name": "dummy", "args": {}, "id": "call_1", "type": "tool_call"}],
        )
        d = _convert_message_to_dict(msg)
        print(f"  serialized: {json.dumps(d, indent=2, default=str)}")
        assert "reasoning_content" in d, (
            f"reasoning_content missing! Monkey-patch not active. "
            f"Keys: {list(d.keys())}"
        )
        assert d["reasoning_content"] == "Chain of thought..."

    def test_thinking_disabled_with_structured_output(self) -> None:
        """Thinking disabled + structured output (json_schema response_format).

        This is the reviewer/retro node scenario.
        """
        model = _make_model(thinking_disabled=True)
        messages = [
            {"role": "system", "content": "You are a reviewer. Output structured feedback."},
            {"role": "user", "content": "Review this PR: fix button click in Safari"},
        ]
        try:
            result = model.invoke(messages, response_format=_REVIEW_SCHEMA)
            print(f"  result: {result.content!r}")
            rc = result.additional_kwargs.get("reasoning_content")
            print(f"  reasoning_content={'present' if rc else 'absent'}")
            assert result.content, "Expected non-empty structured output"
        except Exception as e:
            err = str(e)
            if "response_format" in err.lower():
                pytest.skip(
                    f"Model {TEST_MODEL['model']} does not support "
                    f"json_schema response_format: {err}"
                )
            raise

    def test_chain_thinking_then_thinking_disabled(self) -> None:
        """Thinking-enabled call -> thinking-disabled call with structured output.

        This is the full scenario: implementer (thinking) -> reviewer
        (thinking-disabled + response_format). Tests that reasoning_content
        is preserved by monkey-patch, and the thinking-disabled call succeeds.
        """
        model_t = _make_model(thinking_disabled=False)
        messages: list[Any] = [
            {"role": "system", "content": "You are a coding assistant. Use the get_weather tool."},
            {"role": "user", "content": "What's the weather in Tokyo?"},
        ]

        # --- Turn 1: thinking-enabled call with tool ---
        try:
            result_t = model_t.invoke(messages, tools=[_WEATHER_TOOL])
        except Exception as e:
            if "thinking" in str(e).lower() and "tool" in str(e).lower():
                pytest.skip(f"Model {TEST_MODEL['model']} does not support thinking + tools")
            raise

        messages.append({
            "role": "assistant",
            "content": result_t.content,
            "tool_calls": [
                {
                    "id": tc["id"],
                    "type": "function",
                    "function": {"name": tc["name"], "arguments": json.dumps(tc["args"])},
                }
                for tc in (result_t.tool_calls or [])
            ],
        })
        if result_t.additional_kwargs.get("reasoning_content"):
            messages[-1]["reasoning_content"] = result_t.additional_kwargs["reasoning_content"]
        rc1 = result_t.additional_kwargs.get("reasoning_content")
        print(f"  Turn 1 reasoning_content={'present' if rc1 else 'absent'}")

        # Tool result
        messages.append({
            "role": "tool",
            "tool_call_id": result_t.tool_calls[0]["id"] if result_t.tool_calls else "call_1",
            "content": '{"temperature": "22°C", "condition": "Sunny"}',
        })

        # Thinking-enabled assistant continuation
        messages.append({
            "role": "assistant",
            "content": "The weather in Tokyo is sunny and 22°C.",
        })

        # --- Turn 2: thinking-disabled call with structured output ---
        model_nt = _make_model(thinking_disabled=True)
        messages.append({
            "role": "user",
            "content": "Review the response for correctness.",
        })

        try:
            result_nt = model_nt.invoke(messages, response_format=_REVIEW_SCHEMA)
            print(f"  Turn 2 result: {result_nt.content!r}")
            rc2 = result_nt.additional_kwargs.get("reasoning_content")
            print(f"  Turn 2 reasoning_content={'present' if rc2 else 'absent'}")
            assert result_nt.content, "Expected non-empty structured output"
        except Exception as e:
            err = str(e)
            if "response_format" in err.lower():
                pytest.skip(
                    f"Model {TEST_MODEL['model']} does not support "
                    f"json_schema response_format: {err}"
                )
            raise
